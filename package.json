{
  "name": "data-driven-content-builder",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "version": "1.0.6",
  "keywords": [],
  "author": "Vladyslav Dudkin",
  "license": "ISC",
  "description": "The package is intended for internal use.",
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "publish": "npm publish --access public"
  },
  "files": ["dist"],
  "exports": {
    "./core": {
      "import": "./dist/core.js",
      "require": "./dist/core.cjs",
      "types": "./dist/core.d.ts"
    },
    "./components": {
      "import": "./dist/components.js",
      "require": "./dist/components.cjs",
      "types": "./dist/components.d.ts"
    }
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "zod": "^3.0.0"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "sideEffects": false
}
